{
  "version": 6,
  "configurePresets": [
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "GRPCMMO_REQUIRE_FRAME_REPO": "ON",
        "GRPCMMO_REQUIRE_DATA_REPO": "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "GRPCMMO_REQUIRE_FRAME_REPO": "ON",
        "GRPCMMO_REQUIRE_DATA_REPO": "ON"
      }
    },
    {
      "name": "windows",
      "displayName": "Windows VS2022",
      "generator": "Visual Studio 17 2022",
      "toolchainFile": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/build/windows",
      "cacheVariables": {
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "GRPCMMO_REQUIRE_FRAME_REPO": "ON",
        "GRPCMMO_REQUIRE_DATA_REPO": "ON"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "inherits": "windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "inherits": "windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "jobs": 8
    },
    {
      "name": "linux-client-debug",
      "configurePreset": "linux-debug",
      "jobs": 8,
      "targets": [
        "grpcmmo_client"
      ]
    },
    {
      "name": "linux-runtime-debug",
      "configurePreset": "linux-debug",
      "jobs": 8,
      "targets": [
        "grpcmmo_auth_server",
        "grpcmmo_game_server",
        "grpcmmo_client"
      ]
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "jobs": 8
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug",
      "jobs": 8
    },
    {
      "name": "windows-client-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug",
      "jobs": 8,
      "targets": [
        "grpcmmo_client"
      ]
    },
    {
      "name": "windows-runtime-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug",
      "jobs": 8,
      "targets": [
        "grpcmmo_auth_server",
        "grpcmmo_game_server",
        "grpcmmo_client"
      ]
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release",
      "jobs": 8
    }
  ]
}
